# Copy to .env before `docker compose up` -- every variable marked
# "set a real ..." in docker-compose.yml will hard-fail the affected
# container if left blank.

# Mongo root credentials -- used by mongo + every service that connects to it.
MONGO_ROOT_USER=dogdock
MONGO_ROOT_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_VALUE

# Signs/validates dashboard login JWTs (agent-api's handlers/auth.go).
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_VALUE


# Only needed if forwarding AWS CloudTrail/EventBridge events to this
# instance's /api/cloudevents/aws. Leave blank to disable that endpoint.
AWS_EVENTBRIDGE_SECRET=

# Optional: dual-write raw agent logs to a GCS bucket for cold storage.
# Leave blank to disable.
GCS_BUCKET=
GCS_PREFIX=agent-logs

# Buffer tuning -- raise BUFFER_SIZE / lower BUFFER_MAX_AGE_SEC if you have
# many agents and want fewer, larger Mongo writes vs. more frequent ones.
BUFFER_SIZE=100
BUFFER_MAX_AGE_SEC=10

# Which published image tag to pull for agent / agent-api / agent-webhook /
# agent-worker. CI pushes one tag per branch (e.g. "main"); pin to a
# specific release tag for anything beyond a trial.
IMAGE_TAG=main
